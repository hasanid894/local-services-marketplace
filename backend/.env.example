# ─── Server ────────────────────────────────────────────────────────────────
PORT=5000

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=local_services_marketplace
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Set to "true" to use PostgreSQL instead of CSV files
USE_DB=true
